# Server
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Database
DATABASE_URL=postgresql://ratingapp:ratingapp@localhost:5432/ratingapp
# Set to "true" for managed Postgres providers that require SSL (e.g. Render, Supabase, Neon)
DATABASE_SSL=false

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-in-development
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=30d

# TMDB — get a free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=
TMDB_BASE_URL=https://api.themoviedb.org/3

# Email — get a free key at https://resend.com/api-keys
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
